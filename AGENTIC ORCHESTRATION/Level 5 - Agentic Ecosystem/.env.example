# Copy this file to ".env" and fill it in. Never commit the real .env.

# --- API keys (same as Level 4) ---
OPENROUTER_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- Model ids (override if you like) ---
OPENROUTER_MODEL=openrouter/free
# Second OpenRouter model — the "openrouter-alt" provider. Same key, different
# model, so it's an easy third voice when another provider is down.
OPENROUTER_MODEL_2=nvidia/nemotron-nano-9b-v2:free
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-3.1-flash-lite
LLM_TEMPERATURE=0.2

# --- Research fan-out ---
# Which providers the research step queries, in order. If your Gemini quota is
# dead, drop it for a 2nd OpenRouter model:
#   RESEARCH_PROVIDERS=openrouter,groq,openrouter-alt
RESEARCH_PROVIDERS=openrouter,groq,gemini

# --- Supabase Postgres connection (from your Level-2 project) ---
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI).
# Use the "Session pooler" URI; replace [YOUR-PASSWORD].
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-REF.supabase.co:5432/postgres

# --- Orchestration ---
MAX_RETRIES=2
