# Copy this file to ".env" and fill in your keys. Never commit the real .env.

# --- API keys (get these during PREWORK) ---
OPENROUTER_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- Model ids (override if you like) ---
OPENROUTER_MODEL=nvidia/llama-nemotron-rerank-vl-1b-v2:free
# Second OpenRouter model — the "openrouter-alt" provider. Same key, different
# model, so it's an easy third voice when another provider is down.
OPENROUTER_MODEL_2=nvidia/nemotron-nano-9b-v2:free
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Research fan-out ---
# Which providers the research step queries, in order. The default uses all three
# vendors. If your Gemini quota is dead, drop it and use a 2nd OpenRouter model:
#   RESEARCH_PROVIDERS=openrouter,groq,openrouter-alt
RESEARCH_PROVIDERS=openrouter,groq,gemini

# --- Generation settings ---
LLM_TEMPERATURE=0.2
